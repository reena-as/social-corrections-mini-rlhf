# Copy to .env and fill in. The scripts read from os.environ so any env loader
# (direnv, dotenv, or just `export VAR=...`) works.

# --- Tinker ---
# Sign up at https://auth.thinkingmachines.ai/sign-up and create an API key
# from https://tinker-console.thinkingmachines.ai
TINKER_API_KEY=

# --- OpenAI (for partner + judge + optional base-model agent) ---
OPENAI_API_KEY=
# Optional: point at a self-hosted OpenAI-compatible endpoint (vLLM, etc.)
# Leave unset to use api.openai.com.
# OPENAI_BASE_URL=https://your-gateway.example.com/v1
